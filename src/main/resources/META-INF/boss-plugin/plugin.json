{
  "manifestVersion": 1,
  "pluginId": "ai.rever.boss.plugin.dynamic.codebase",
  "displayName": "Codebase (Dynamic)",
  "version": "1.0.10",
  "apiVersion": "1.0.20",
  "minBossVersion": "8.16.30",
  "mainClass": "ai.rever.boss.plugin.dynamic.codebase.CodebaseDynamicPlugin",
  "type": "panel",
  "description": "Browse and explore project files",
  "author": "Risa Labs",
  "url": "https://github.com/risa-labs-inc/boss-plugin-codebase",
  "panel": {
    "position": "left_top_top",
    "priority": 2
  },
  "sandbox": {
    "maxThreads": 4,
    "maxRestartAttempts": 3,
    "heartbeatIntervalMs": 5000
  },
  "isolationMode": "out-of-process",
  "fallback": "in-process",
  "stateHolderClass": "ai.rever.boss.plugin.runtime.stateholders.CodebaseStateHolder"
}
